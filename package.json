{
  "name": "protein-viewer-multireview",
  "displayName": "Protein Viewer MultiReview",
  "description": "Visualise 3D biological structures in the editor",
  "version": "0.1.1",
  "publisher": "zhaolong",
  "author": {
    "name": "zhaolong"
  },
  "icon": "img/logo.png",
  "engines": {
    "vscode": "^1.62.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Schmoo2333/VSCoding-Sequence-protein-viewer-multireview"
  },
  "license": "MIT",
  "categories": [
    "Other",
    "Visualization",
    "Data Science"
  ],
  "keywords": [
    "protein",
    "molecule",
    "biology",
    "3d",
    "structure",
    "pdb",
    "pdbqt",
    "mmcif",
    "sdf",
    "ent",
    "mol",
    "mol2",
    "xyz",
    "cif",
    "gro",
    "macromolecule",
    "bioinformatics",
    "computational biology",
    "chemistry",
    "cheminformatics",
    "computational chemistry"
  ],
  "activationEvents": [
    "onCommand:protein-viewer-multireview.start",
    "onCommand:protein-viewer-multireview.activateFromFiles",
    "onCommand:protein-viewer-multireview.activateFromFolder",
    "onCommand:protein-viewer-multireview.ESMFold"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "protein-viewer-multireview.start",
        "title": "Start Protein Viewer MultiReview"
      },
      {
        "command": "protein-viewer-multireview.activateFromFiles",
        "title": "Open Protein Viewer MultiReview from File(s)"
      },
      {
        "command": "protein-viewer-multireview.activateFromFolder",
        "title": "Open Protein Viewer MultiReview from Folder"
      },
      {
        "command": "protein-viewer-multireview.ESMFold",
        "title": "Protein Viewer MultiReview: ESMFold Sequence"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "when": "resourceFilename =~ /\\.(pdb|pdbqt|mmcif|mcif|cif|gro|xyz|mol|mol2|sdf|ent)(\\.gz)?$/i",
          "command": "protein-viewer-multireview.activateFromFiles",
          "group": "navigation"
        },
        {
          "when": "explorerResourceIsFolder",
          "command": "protein-viewer-multireview.activateFromFolder",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/glob": "^7.1.4",
    "@types/mocha": "^9.0.0",
    "@types/node": "^16.18.11",
    "@types/vscode": "^1.62.0",
    "@typescript-eslint/eslint-plugin": "^5.1.0",
    "@typescript-eslint/parser": "^5.1.0",
    "@vscode/test-electron": "^1.6.2",
    "eslint": "^8.57.1",
    "glob": "^7.1.7",
    "mocha": "^9.1.3",
    "typescript": "^4.4.4"
  },
  "dependencies": {
    "molstar": "^4.8.0",
    "node-fetch": "^2.6.1",
    "vscode-uri": "^3.0.8",
    "yarn": "^1.22.22"
  }
}
